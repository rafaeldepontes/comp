struct Point {
    x: number,
    y: number
}

impl Point {
    fn add(other: Point): Point {
        let p = new Point();
        p.x = this.x + other.x;
        p.y = this.y + other.y;
        return p;
    }
}

let p1 = new Point();
p1.x = 10;
p1.y = 20;

let p2 = new Point();
p2.x = 5;
p2.y = 5;

let p3: Point = p1.add(p2);
