fn dontKnow(action: string) {
    if action == "know" {
        print("I know that");
    } else {
        print("Idk what this means");
    }

    // clear the action, don't have any motive
    // just testing actions
    action = "";

    let arr1: []number = [1, 2, 3];
    arr1[0] += arr1[len(arr1)-1];
    print("This is the expected outcome: %d", arr1[0]);

    let arr2 : [][]number = arr1[0..len(arr1)-1];
}